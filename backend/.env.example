# TaskForge Backend Environment Variables
# Copy this file to .env and fill in the values

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5433/taskforge

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# JWT Configuration (REQUIRED for production)
# Generate a secure random key: openssl rand -base64 64
JWT_SECRET_KEY=your-secure-random-key-here-minimum-64-characters

# JWT Algorithm (default: HS256)
JWT_ALGORITHM=HS256

# JWT Token Expiration (minutes, default: 1440 = 24 hours)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OpenAI API Key (required for AI features)
OPENAI_API_KEY=your-openai-api-key-here

# CORS Configuration (for production)
# CORS_ALLOWED_ORIGINS=https://taskforge.example.com,https://app.taskforge.example.com